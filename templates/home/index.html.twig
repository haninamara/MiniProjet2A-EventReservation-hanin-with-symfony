{% extends 'base.html.twig' %}

{% block title %}Home{% endblock %}

{% block body %}

{# Flash messages #}
{% for message in app.flashes('success') %}
    <div class="alert alert-success">{{ message }}</div>
{% endfor %}

<h1>Events</h1>

<div class="row mt-4">
    {% for event in events %}
    <div class="col-md-4 mb-3">
        <div class="card">
            {% if event.image %}
                <img src="{{ asset('uploads/' ~ event.image) }}" class="card-img-top" alt="{{ event.title }}">
            {% endif %}
            <div class="card-body">
                <h5 class="card-title">{{ event.title }}</h5>
                <p class="card-text">{{ event.description|slice(0, 100) ~ '...' }}</p>
                <p><strong>Date:</strong> {{ event.date|date('d/m/Y H:i') }}</p>
                <p><strong>Location:</strong> {{ event.location }}</p>
                <p><strong>Available Seats:</strong> {{ event.seats - event.reservations|length }}</p>

                {% if event.seats - event.reservations|length > 0 %}
                    <a href="{{ path('app_event_reserve', {'id': event.id}) }}" class="btn btn-primary">Reserve</a>
                {% else %}
                    <span class="text-danger">Full</span>
                {% endif %}
            </div>
        </div>
    </div>
    {% else %}
        <p>No events available.</p>
    {% endfor %}
</div>
{% endblock %}