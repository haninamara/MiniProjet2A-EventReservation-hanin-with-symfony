<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Welcome!{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_home') }}">Mon App</a>
            <div class="navbar-nav ms-auto">
                {% if app.user %}
                    <span class="navbar-text me-3">
                        Bienvenue, {{ app.user.username }} !
                    </span>
                    <a class="btn btn-outline-light btn-sm" href="{{ path('app_logout') }}">
                        Déconnexion
                    </a>
                {% else %}
                    <a class="btn btn-outline-light btn-sm me-2" href="{{ path('app_login') }}">
                        Connexion
                    </a>
                    <a class="btn btn-primary btn-sm" href="{{ path('app_register') }}">
                        Inscription
                    </a>
                {% endif %}
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        {% block body %}{% endblock %}
    </div>
</body>
</html>