{% extends 'base.html.twig' %}

{% block title %}Réservations - {{ event.title }}{% endblock %}

{% block body %}
<h2>Réservations pour : {{ event.title }}</h2>

<table class="table table-striped mt-3">
    <thead>
        <tr>
            <th>Nom</th>
            <th>Email</th>
            <th>Téléphone</th>
            <th>Date de création</th>
        </tr>
    </thead>
    <tbody>
        {% for reservation in reservations %}
            <tr>
                <td>{{ reservation.name }}</td>
                <td>{{ reservation.email }}</td>
                <td>{{ reservation.phone }}</td>
                <td>{{ reservation.createdAt|date('d/m/Y H:i') }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">Aucune réservation</td>
            </tr>
        {% endfor %}
    </tbody>
</table>

<a href="{{ path('admin_event_index') }}" class="btn btn-secondary mt-3">Retour</a>
{% endblock %}